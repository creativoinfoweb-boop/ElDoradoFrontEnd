# Copia come .env.local (il file .env.local non va mai su Git).
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Clerk — solo chiave pubblica nel client (Dashboard → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Secret per middleware/server Next.js: stesso valore in .env.local, mai in repo
CLERK_SECRET_KEY=

# Opzionale: proxy Stripe → backend
# STRIPE_WEBHOOK_FORWARD_URL=http://127.0.0.1:8000/subscriptions/webhook/stripe
